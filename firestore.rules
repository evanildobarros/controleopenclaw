rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required, immutable) - User ID
    //   - email: string (required, immutable) - User email
    //   - displayName: string (optional) - User display name
    //   - photoURL: string (optional) - User photo URL
    //   - createdAt: timestamp (required, immutable) - Creation time
    //
    // Collection: agents
    // Document ID: {agentId}
    // Fields:
    //   - ownerId: string (required, immutable) - User ID of owner
    //   - name: string (required, immutable) - Agent name
    //   - role: string (required, immutable) - Agent role
    //   - status: string (required) - Agent status ('idle', 'working', 'offline', 'error')
    //   - currentTask: string (optional) - Current task description
    //   - updatedAt: timestamp (required) - Last update time
    //
    // Collection: tasks
    // Document ID: {taskId}
    // Fields:
    //   - ownerId: string (required, immutable) - User ID of creator
    //   - agentId: string (required, immutable) - Assigned agent ID
    //   - description: string (required, immutable) - Task description
    //   - status: string (required) - Task status ('pending', 'in-progress', 'completed', 'failed')
    //   - createdAt: timestamp (required, immutable) - Creation time
    //   - completedAt: timestamp (optional) - Completion time
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }

    function isRequestOwner() {
      return isAuthenticated() && request.auth.uid == request.resource.data.ownerId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser() {
      return hasOnlyAllowedFields(['uid', 'email', 'displayName', 'photoURL', 'createdAt']) &&
             hasRequiredFields(['uid', 'email', 'createdAt']) &&
             request.resource.data.uid == request.auth.uid &&
             request.resource.data.email is string &&
             request.resource.data.createdAt is timestamp &&
             (!('displayName' in request.resource.data) || (request.resource.data.displayName is string && request.resource.data.displayName.size() <= 100)) &&
             (!('photoURL' in request.resource.data) || (request.resource.data.photoURL is string && request.resource.data.photoURL.size() <= 1000));
    }

    function isValidAgent() {
      return hasOnlyAllowedFields(['ownerId', 'name', 'role', 'status', 'currentTask', 'updatedAt']) &&
             hasRequiredFields(['ownerId', 'name', 'role', 'status', 'updatedAt']) &&
             request.resource.data.ownerId == request.auth.uid &&
             request.resource.data.name is string && request.resource.data.name.size() > 0 && request.resource.data.name.size() <= 50 &&
             request.resource.data.role is string && request.resource.data.role.size() > 0 && request.resource.data.role.size() <= 50 &&
             request.resource.data.status in ['idle', 'working', 'offline', 'error'] &&
             request.resource.data.updatedAt is timestamp &&
             (!('currentTask' in request.resource.data) || (request.resource.data.currentTask is string && request.resource.data.currentTask.size() <= 500));
    }

    function isValidTask() {
      return hasOnlyAllowedFields(['ownerId', 'agentId', 'description', 'status', 'createdAt', 'completedAt']) &&
             hasRequiredFields(['ownerId', 'agentId', 'description', 'status', 'createdAt']) &&
             request.resource.data.ownerId == request.auth.uid &&
             request.resource.data.agentId is string && request.resource.data.agentId.size() > 0 && request.resource.data.agentId.size() <= 100 &&
             request.resource.data.description is string && request.resource.data.description.size() > 0 && request.resource.data.description.size() <= 1000 &&
             request.resource.data.status in ['pending', 'in-progress', 'completed', 'failed'] &&
             request.resource.data.createdAt is timestamp &&
             (!('completedAt' in request.resource.data) || request.resource.data.completedAt is timestamp);
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser();
      allow update: if isOwner(userId) && isValidUser() && areImmutableFieldsUnchanged(['uid', 'email', 'createdAt']);
      allow delete: if false;
    }

    match /agents/{agentId} {
      allow read: if isDocOwner();
      allow create: if isRequestOwner() && isValidAgent();
      allow update: if isDocOwner() && isRequestOwner() && isValidAgent() && areImmutableFieldsUnchanged(['ownerId', 'name', 'role']);
      allow delete: if isDocOwner();
    }

    match /tasks/{taskId} {
      allow read: if isDocOwner();
      allow create: if isRequestOwner() && isValidTask();
      allow update: if isDocOwner() && isRequestOwner() && isValidTask() && areImmutableFieldsUnchanged(['ownerId', 'agentId', 'description', 'createdAt']);
      allow delete: if isDocOwner();
    }
  }
}
